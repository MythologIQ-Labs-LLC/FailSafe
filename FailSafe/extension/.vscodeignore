# Source files
src/**

# Exclude TypeScript compile output from the package; runtime ships from /dist
out/**

# Compiled test output
out/test/**

# Development files
.vscode/
.vscode-test/
.vscode-test.json
.vscode-test.mjs
.nvmrc
tsconfig.json
.eslintrc.cjs
playwright.config.ts

# Test files
test-results/
**/*.test.ts
**/*.test.js

# Build scripts
scripts/

# Documentation (keep README, CHANGELOG, LICENSE)
*.md
!README.md
!CHANGELOG.md
!docs/COMPONENT_HELP.md
!docs/PROCESS_GUIDE.md

# v5: bundled skills are no longer shipped with the extension. Skills are
# installed at runtime from the qor-logic PyPI package via the
# QorLogicSkillIngestor flow.
dist/extension/skills/**

# Bundle runtime dependencies aggressively; keep only native sqlite support
node_modules/**
!node_modules/better-sqlite3/package.json
!node_modules/better-sqlite3/LICENSE
!node_modules/better-sqlite3/lib/**
!node_modules/better-sqlite3/build/Release/**
!node_modules/bindings/package.json
!node_modules/bindings/LICENSE.md
!node_modules/bindings/bindings.js
!node_modules/file-uri-to-path/package.json
!node_modules/file-uri-to-path/LICENSE
!node_modules/file-uri-to-path/index.js

# Git
.git/
.gitignore

# Misc
**/*.map
*.vsix
.DS_Store
Thumbs.db

# Secrets - NEVER include
.vsce-token
.ovsx-token
*.token
.env
.env.*

# Proprietary/system-internal artifacts
**/proprietary/**
**/.proprietary/**
**/internal/**
**/.internal/**
**/private/**
**/.private/**

# Old icon files
old-icon.png

# Voice Pack — extracted to a separate companion download (B195 resolution).
# Plan: docs/plan-qor-voice-substrate-extraction.md Phase 4.
# Heavy vendor binaries (~86 MB) are operator-installed via
# `failsafe.installVoicePack`, not shipped in the base VSIX.
dist/extension/ui/vendor/piper/**
dist/extension/ui/vendor/whisper/**
dist/failsafe-voice-pack-*.tar.gz
dist/failsafe-voice-pack-*.sha256
